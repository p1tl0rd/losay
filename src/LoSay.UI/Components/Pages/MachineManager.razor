@page "/machines"
@inject LoSay.Servies.Interfaces.IMachineService MachineService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject ILogger<MachineManager> Logger
@using LoSay.Components.Shared
@using MudBlazor

<MudText Typo="Typo.h4" Class="mb-4">Qu?n l˝ M·y</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ShowAddDialog" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Add" Class="mr-1" />
    ThÍm M·y m?i
</MudButton>

<MudGrid Spacing="3">
    @if (machines != null)
    {
        @foreach (var machine in machines)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="3" Class="d-flex flex-column">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@machine.MachineName</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudTooltip Text="Ch?nh s?a">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="@(() => ShowEditDialog(machine))" />
                            </MudTooltip>
                            <MudTooltip Text="XÛa">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => ConfirmDelete(machine.Id))" />
                            </MudTooltip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="flex-grow-1">
                        <MudText Typo="Typo.body2"><b>ID:</b> @machine.Id</MudText>
                        <MudText Typo="Typo.body2"><b>–?a Ch?:</b> @machine.Address</MudText>
                        <MudText Typo="Typo.body2"><b>Lot Run:</b> @machine.LotRun</MudText>
@*                         <MudText Typo="Typo.body2">
                            <b>Ho‡n th‡nh Lot:</b> @((machine.FinishLot == true) ? "Yes" : "No")
                        </MudText> *@
                        <MudChip T="string" Color="@(Convert.ToBoolean(machine.Status) == true ? Color.Success : Color.Error)" Class="mt-2">
                            @((Convert.ToBoolean(machine.Status) == true) ? "Ho?t d?ng" : "Ngung")
                        </MudChip>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    }
    else
    {
        <MudItem xs="12">
            <MudProgressCircular Color="Color.Info" Indeterminate="true" />
        </MudItem>
    }
</MudGrid>

@code {
    private List<Machine>? machines;

    protected override async Task OnInitializedAsync()
    {
        await LoadMachines();
    }

    private async Task LoadMachines()
    {
        try
        {
            machines = await MachineService.GetMachinesAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "L?i t?i danh s·ch m·y");
            Snackbar.Add("L?i t?i danh s·ch m·y", Severity.Error);
        }
    }

    private async Task ShowAddDialog()
    {
        var parameters = new DialogParameters { ["Machine"] = new Machine() };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<MachineEditDialog>("ThÍm M·y m?i", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadMachines();
            Snackbar.Add("ThÍm m·y th‡nh cÙng", Severity.Success);
        }
    }

    private async Task ShowEditDialog(Machine machine)
    {
        var parameters = new DialogParameters { ["Machine"] = machine };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<MachineEditDialog>("S?a M·y", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled)
        {
            await LoadMachines();
            Snackbar.Add("C?p nh?t m·y th‡nh cÙng", Severity.Success);
        }
    }

    private async Task ConfirmDelete(int id)
    {
        bool? result = await DialogService.ShowMessageBox(
            "X·c nh?n",
            $"B?n cÛ ch?c ch?n mu?n xÛa m·y Id {id}?",
            yesText: "XÛa", cancelText: "H?y");

        if (result == true)
        {
            try
            {
                await MachineService.DeleteMachineAsync(id);
                await LoadMachines();
                Snackbar.Add("XÛa m·y th‡nh cÙng", Severity.Success);
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "L?i khi xÛa m·y");
                Snackbar.Add("L?i khi xÛa m·y", Severity.Error);
            }
        }
    }
}
