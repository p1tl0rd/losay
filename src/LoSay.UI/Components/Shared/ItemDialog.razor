@using LoSay.Data.Entities
@inject IItemService ItemService
@inject IDialogService DialogService
@using LoSay.Servies.Interfaces
@using MudBlazor

<MudDialog>
    <DialogContent>
        <EditForm Model="Item" OnValidSubmit="Save">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.ItemCode" Label="M„ Item" Required RequiredError="M„ Item lý b?t bu?c" MaxLength="50" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.ItemName" Label="TÍn Item" Required RequiredError="TÍn Item lý b?t bu?c" MaxLength="50" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Item.Max" Label="Max Value" Required RequiredError="Max Value lý b?t bu?c" Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Item.Min" Label="Min Value" Required RequiredError="Min Value lý b?t bu?c" Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.TimeSamping" Label="Time Sampling (gi‚y)" Required RequiredError="Time Sampling lý b?t bu?c" Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox @bind-Checked="Item.Status" T="bool?" Label="Tr?ng th·i ho?t d?ng" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
            <DataAnnotationsValidator />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">H?y</MudButton>
        <MudButton Color="Color.Primary" OnClick="HandleSubmit">Luu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public Item Item { get; set; } = new Item();

    private async Task Save()
    {
        if (Item.Id == 0)
        {
            await ItemService.AddItemAsync(Item);
        }
        else
        {
            await ItemService.UpdateItemAsync(Item);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task HandleSubmit()
    {
        // MudForm khÙng cÛ Validate() khi d˘ng EditForm, ValidationMessage s? t? hi?n th?
        await Save();
    }
}
