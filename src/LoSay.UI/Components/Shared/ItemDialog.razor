@inject IItemService ItemService
@inject IDialogService DialogService
@using MudBlazor

<MudDialog>
    <DialogContent>
        <EditForm Model="Item" OnValidSubmit="Save">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.ItemCode" Label="Mã Item" Required RequiredError="Mã Item là bắt buộc" MaxLength="50" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.ItemName" Label="Tên Item" Required RequiredError="Tên Item là bắt buộc" MaxLength="50" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Item.Max" Label="Max Value" Required RequiredError="Max Value là bắt buộc" Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Item.Min" Label="Min Value" Required RequiredError="Min Value là bắt buộc" Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Item.TimeSamping" Label="Time Sampling (giây)" Required RequiredError="Time Sampling là bắt buộc" Variant="Variant.Outlined" InputType="InputType.Number" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox @bind-Checked="Item.Status" T="bool" Label="Trạng thái hoạt động" Color="Color.Primary" />
                </MudItem>
            </MudGrid>
            <DataAnnotationsValidator />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="HandleSubmit">Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public ItemDto Item { get; set; } = new ItemDto();

    private async Task Save()
    {
        if (Item.Id == 0)
        {
            await ItemService.CreateItemAsync(Item);
        }
        else
        {
            await ItemService.UpdateItemAsync(Item);
        }
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private async Task HandleSubmit()
    {
        await Save();
    }
}
