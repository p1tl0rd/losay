@using MudBlazor
@inject IMachineService MachineService
@inject ISnackbar Snackbar
@inject ILogger<MachineEditDialog> Logger
@inject IDialogService DialogService

@using LoSay.Components.Pages

<MudDialog>
    <DialogContent>
        <EditForm Model="Machine" OnValidSubmit="Save">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Machine.MachineName" Label="Tên Máy" Required RequiredError="Tên máy là bắt buộc" MaxLength="10" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Machine.Address" Label="Địa Chỉ PLC" MaxLength="20" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudCheckBox @bind-Value="Machine.Status" Color="Color.Success" Label="Trạng thái hoạt động"></MudCheckBox>
                </MudItem>
            </MudGrid>
            <DataAnnotationsValidator />
        </EditForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" OnClick="HandleSubmit" >Lưu</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter]
    public MachineDto Machine { get; set; } = new();
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }
    private string ButtonText => Machine.Id == 0 ? "Thêm" : "Lưu";
    private bool isValid;
    private async Task Save()
    {
        try
        {
            if (Machine.Id == 0)
            {
                await MachineService.CreateMachineAsync(Machine);
            }
            else
            {
                await MachineService.UpdateMachineAsync(Machine);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Lỗi lưu máy");
            Snackbar.Add("Lỗi khi lưu máy", Severity.Error);
        }
    }

    private void Cancel()
    {
        MudDialog.Close(DialogResult.Ok(true));
    }
    private async Task HandleSubmit()
    {
        await Save();
    }
}
