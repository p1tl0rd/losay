@using LoSay.Application.DTOs
@inject IDialogService DialogService
@using MudBlazor


<MudDialog>
    <DialogContent>

        @* <MudText Typo="Typo.h6">Audit Detail</MudText> *@

        @* <MudText><b>Primary Key</b></MudText> *@

        @if (!string.IsNullOrEmpty(Audit.OldValues))
        {
            <MudText><b>Old Values</b></MudText>
            <MudPaper Class="pa-3" Elevation="0">
                <pre style="white-space: pre-wrap; word-break: break-word;">
                @Audit.OldValues
            </pre>
            </MudPaper>
        }

        @if (!string.IsNullOrEmpty(Audit.NewValues))
        {
            <MudText><b>New Values</b></MudText>
            <MudPaper Class="pa-3" Elevation="0">
                <pre style="white-space: pre-wrap; word-break: break-word;">
            @Audit.NewValues
            </pre>
            </MudPaper>
        }

    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Primary" OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public AuditLogDto Audit { get; set; } = null!;
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    void Close() => MudDialog.Close();
}
