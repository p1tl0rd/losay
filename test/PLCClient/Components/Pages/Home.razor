@page "/"
@inject IMachineService machineService
@inject NavigationManager NavigationManager

<PageTitle>Machine Overview</PageTitle>
<style>
	.machine-card:hover {
		box-shadow: 0 8px 17px 0 rgba(0, 0, 0, 0.2);
		transform: translateY(-2px);
	}
</style>

<MudContainer>
	<MudText Typo="Typo.h4" GutterBottom="true">Machine Status</MudText>
	@if (machines != null )
	{
		<MudGrid Spacing="4">
			@foreach (var machine in machines)
			{
				<MudItem xs="12" sm="6" md="4" lg="3">
					<MudCard Elevation="3" Class="machine-card"
							 @onclick="@(() => NavigationManager.NavigateTo($"/MachineDetail/{machine.MachineName}?id={machine.Id}"))"
							 Style="cursor: pointer;">
						<MudCardHeader>
							<CardHeaderContent>
								<MudText Typo="Typo.h6">@machine.MachineName</MudText>
							</CardHeaderContent>
							<CardHeaderActions>
								@if (!string.IsNullOrEmpty(machine.LotRun))
								{
									<MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Icon="@Icons.Material.Filled.PlayArrow">
										Running
									</MudChip>
								}
								else
								{
									<MudChip T="string" Color="Color.Info" Variant="Variant.Filled" Icon="@Icons.Material.Filled.CheckCircleOutline">
										Ready
									</MudChip>
								}

							</CardHeaderActions>
						</MudCardHeader>
						<MudCardContent>

							<MudText Typo="Typo.body2">
								<b>Lot Run:</b> @machine.LotRun
							</MudText>

							<MudText Typo="Typo.body2">
								<b>Start Time:</b> @machine.StartTime?.ToString("dd.MMM.yy HH:mm")
							</MudText>
							<MudText Typo="Typo.body2">
								<b>Elapsed:</b>
							</MudText>
							<MudSimpleTable Dense="true" Style="border:none;overflow-x: auto;">
								<thead>
									<tr>
										<th>CH1</th>
										<th>CH2</th>
										<th>CH3</th>
									</tr>
								</thead>
								<tbody>
									<tr>
										<td>@machine.PLCDataDto.Value1</td>
										<td>@machine.PLCDataDto.Value2</td>
										<td>@machine.PLCDataDto.Value3</td>
									</tr>
								</tbody>
							</MudSimpleTable>
							<MudText Typo="Typo.body2">
							 
							</MudText>
						</MudCardContent>
					</MudCard>
				</MudItem>
			}
		</MudGrid>
	}
	else
	{
		<MudAlert Severity="Severity.Warning">Đang chờ dữ liệu...</MudAlert>
	}




</MudContainer>

@code {

	IEnumerable<MachineWithLotInfoDto> machines;
	private HubConnection? hubConnection;
	private bool isConnected = false;

	private Dictionary<int, string?> _lotNos = new Dictionary<int, string?>();
	private Dictionary<int, DateTime?> _startTimes = new Dictionary<int, DateTime?>();

	protected override async Task OnInitializedAsync()
	{
	//	machines = await machineService.GetMachinesWithLotInfoAsync();
		await InitSignalR();
	}

	//Signal R
	private async Task InitSignalR()
	{
		hubConnection = new HubConnectionBuilder()
		.WithUrl(NavigationManager.ToAbsoluteUri("/dashboardhub"))
			.WithAutomaticReconnect()
			.Build();

		hubConnection.On<IEnumerable<MachineWithLotInfoDto>>("ReceiveDashboardData", data =>
		{
			if (data != null)
			{
				machines = data; // cập nhật danh sách máy
				InvokeAsync(StateHasChanged);
			}
		});


		await hubConnection.StartAsync();

		if (hubConnection.State == HubConnectionState.Connected)
		{
			isConnected = true;
			await hubConnection.InvokeAsync("JoinDashboardGroup");
		}
		else
		{
			Console.WriteLine("⚠️ SignalR not connected, cannot send commands.");
		}
	}
}